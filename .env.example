# =============================================================================
# Viva — environment template
# =============================================================================
# Copy this file to `.env` and/or `.env.local` in the repo root and fill in
# values. Never commit real keys.
#
# - Next.js loads `.env.local`, `.env`, etc. from the project root (built-in).
# - FastAPI loads the same root `.env` then `.env.local` via python-dotenv
#   (see backend/config.py).
# =============================================================================

# --- Required for POST /upload (Llama 3 on Groq) ---
GROQ_API_KEY=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

# --- Optional: deep URL ingestion ---
# Firecrawl — LinkedIn, JS-heavy portfolios (markdown extraction)
FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v1/scrape
# GitHub — higher rate limits for private /api repos
GITHUB_TOKEN=

# Docling — default is lightweight PDF (no OCR / table / formula model weights).
# VIVA_DOC_FULL_PIPELINE=true  # enable formulas + heavier pipeline (also honors VIVA_DOC_FORMULAS)
# VIVA_DOC_FORMULAS=true       # only when VIVA_DOC_FULL_PIPELINE=true
# Crawl4AI — set false to use only httpx/BeautifulSoup for non-GitHub URLs
# VIVA_USE_CRAWL4AI=true

# --- Frontend (safe for browser; only NEXT_PUBLIC_* is exposed to the client)
# Local dev: same-origin proxy (next.config.ts rewrites /api/* → FastAPI :8000/*; no CORS).
NEXT_PUBLIC_API_URL=/api
# Production or calling FastAPI directly (no Next rewrite): use an absolute URL instead, e.g.
# NEXT_PUBLIC_API_URL=https://api.example.com
# Optional path prefix only when using an absolute base above:
# NEXT_PUBLIC_API_PATH_PREFIX=

# --- Frontend (Next.js)
# Used for client-side Auth, Storage, or Realtime features
NEXT_PUBLIC_SUPABASE_URL=https://xwolbcdwdbgfbnrhcvqg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xAH41iglLC-QL6kIb5MMZg_p69LoOoj

# --- Database
DATABASE_URL=postgresql://postgres:teamNode.NEXT@db.xwolbcdwdbgfbnrhcvqg.supabase.co:5432/postgres

# --- FastAPI
# Comma-separated origins for CORS (main.py also always allows :3000 and :3001)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Llama 3 (question generation & answer scoring)
# Provider: groq | replicate | ollama
LLAMA_PROVIDER=groq
# Primary API key for your LLM host (e.g. Groq secret key)
LLAMA_API_KEY=LLM|962535266497483|cPveuZdnRyPZTk-TALiqQVzHtto
# Optional: set explicitly if you use Groq and prefer a dedicated variable
GROQ_API_KEY=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

# Local Ollama (when LLAMA_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLAMA_MODEL=llama-3.3-70b-versatile

# --- Transcription (Whisper or compatible APIs)
# e.g. openai | groq (match your SDK)
WHISPER_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3-turbo
